# ---- Core ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:3000
# Public base URL of this API (for building referral/redirect/callback URLs)
API_PUBLIC_URL=http://localhost:4000
# Public base URL of the web app
WEB_PUBLIC_URL=http://localhost:3000

# ---- Database / cache ----
DATABASE_URL=postgresql://referraios:referraios@localhost:5432/referraios?schema=public
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ---- AI (Anthropic Claude is the default provider) ----
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL_SMART=claude-opus-4-8
AI_MODEL_FAST=claude-sonnet-4-6
# Optional fallback provider
GEMINI_API_KEY=

# ---- Payments: M-PESA Daraja ----
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_B2C_INITIATOR=
MPESA_B2C_SECURITY_CREDENTIAL=
MPESA_CALLBACK_BASE_URL=

# ---- Payments: Flutterwave ----
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_WEBHOOK_HASH=

# ---- Billing: Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# ---- Platform economics ----
# Platform fee taken on each commission payout, in basis points (e.g. 500 = 5%)
PLATFORM_FEE_BPS=0
